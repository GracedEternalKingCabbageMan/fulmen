{
  "name": "fulmen",
  "productName": "Fulmen",
  "version": "0.2.0",
  "description": "Fulmen — a lightning-fast desktop wallet for SeqLN, the Sequentia Lightning Network. Ships with a bundled SeqLN node: point it at a Sequentia node and go. Asset channels, any-asset payments, and pure-LN asset↔BTC swaps.",
  "author": "Concatena Labs",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "rpc-smoke": "node src/main/cln.js",
    "node-smoke": "node src/main/node.js",
    "bundle:seqln": "bash build/make-seqln-bundle.sh",
    "bundle:rootfs": "bash build/make-wsl-rootfs.sh",
    "icon": "node build/make-icon.js",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:win": "electron-builder --win zip",
    "dist": "electron-builder --linux AppImage --win zip"
  },
  "build": {
    "appId": "io.sequentia.fulmen",
    "productName": "Fulmen",
    "directories": { "output": "dist", "buildResources": "build" },
    "files": ["src/**/*", "package.json"],
    "linux": {
      "target": ["AppImage"],
      "category": "Finance",
      "icon": "build/icon.png",
      "artifactName": "Fulmen-${version}-linux-x86_64.${ext}",
      "extraResources": [ { "from": "build/seqln-linux-x64", "to": "seqln" } ]
    },
    "win": {
      "target": ["zip"],
      "signAndEditExecutable": false,
      "artifactName": "Fulmen-${version}-win64.${ext}",
      "extraResources": [ { "from": "build/wsl", "to": "wsl", "filter": ["*.tar"] } ]
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
